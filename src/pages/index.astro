---
import Layout from "../layouts/MainLayout.astro";
import {
  FileText,
  CircleDollarSign,
  HelpCircle,
  Clock,
  MapPin,
  ClipboardCheck,
} from "@lucide/astro";
---

<Layout title="Juzgado de Faltas Municipal | Catamarca">
  <!-- Barra rápida -->
  <section class="bg-blue-50 border-b border-blue-100">
    <div
      class="max-w-7xl mx-auto px-4 py-2 flex flex-wrap gap-4 justify-center text-sm font-medium"
    >
      <a
        href="https://multasinfojuzgado.netlify.app/"
        target="_blank"
        rel="noreferrer"
        class="text-blue-700 hover:underline"
      >
        🚗 Consultar multas
      </a>
      <a
        href="https://libredeuda.apps.cc.gob.ar/"
        target="_blank"
        rel="noreferrer"
        class="text-emerald-700 hover:underline"
      >
        📄 Libre deuda
      </a>
      <a
        href="https://pagosonlinejuzgado.netlify.app/"
        target="_blank"
        rel="noreferrer"
        class="text-indigo-700 hover:underline"
      >
        💳 Pagar multas
      </a>
      <a href="#atencion" class="text-slate-700 hover:underline">
        🕒 Atención presencial
      </a>
    </div>
  </section>

  <!-- Hero -->
  <section
    class="bg-linear-to-r from-slate-800 via-blue-900 to-indigo-900 text-white"
  >
    <div class="max-w-7xl mx-auto px-6 py-20 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">
        Juzgado de Faltas Municipal
      </h1>
      <p class="text-lg md:text-xl text-white/85 max-w-2xl mx-auto mb-6">
        Consultá, resolvé y pagá tus infracciones de forma rápida, clara y sin
        hacer filas.
      </p>

      <div class="flex justify-center gap-3 flex-wrap">
        <span class="bg-white/10 backdrop-blur px-5 py-2 rounded-full text-sm"
          >✔️ 100% online</span
        >
        <span class="bg-white/10 backdrop-blur px-5 py-2 rounded-full text-sm"
          >✔️ Oficial</span
        >
        <span class="bg-white/10 backdrop-blur px-5 py-2 rounded-full text-sm"
          >✔️ Sin trámites innecesarios</span
        >
      </div>
    </div>
  </section>

  <!-- Accesos principales -->
  <section class="bg-white py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-slate-800 text-center mb-3">
        ¿Qué querés hacer ahora?
      </h2>
      <p class="text-center text-slate-500 mb-12">
        Accedé directamente a los trámites más usados
      </p>

      <div class="grid gap-7 md:grid-cols-3">
        <!-- Multas -->
        <a
          href="https://multasinfojuzgado.netlify.app/"
          target="_blank"
          rel="noreferrer"
          class="group bg-slate-50 rounded-2xl p-7 shadow-sm hover:shadow-md transition hover:-translate-y-1 border border-slate-200"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="bg-blue-100 text-blue-700 p-3 rounded-xl">
              <HelpCircle size={22} />
            </div>
            <h3 class="font-semibold text-lg text-slate-800">
              Tengo una multa
            </h3>
          </div>
          <p class="text-slate-600 text-sm mb-5">
            Consultá qué significa, si está vigente y qué opciones tenés para
            resolverla.
          </p>
          <span class="text-blue-700 font-semibold group-hover:underline">
            Ver información →
          </span>
        </a>

        <!-- Libre deuda -->
        <a
          href="https://libredeuda.apps.cc.gob.ar/"
          target="_blank"
          rel="noreferrer"
          class="group bg-slate-50 rounded-2xl p-7 shadow-sm hover:shadow-md transition hover:-translate-y-1 border border-slate-200"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="bg-emerald-100 text-emerald-700 p-3 rounded-xl">
              <FileText size={22} />
            </div>
            <h3 class="font-semibold text-lg text-slate-800">
              Necesito libre deuda
            </h3>
          </div>
          <p class="text-slate-600 text-sm mb-5">
            Solicitá tu certificado en minutos desde el sistema oficial.
          </p>
          <span class="text-emerald-700 font-semibold group-hover:underline">
            Solicitar →
          </span>
        </a>

        <!-- Pagos -->
        <a
          href="https://pagosonlinejuzgado.netlify.app/"
          target="_blank"
          rel="noreferrer"
          class="group bg-slate-50 rounded-2xl p-7 shadow-sm hover:shadow-md transition hover:-translate-y-1 border border-slate-200"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="bg-indigo-100 text-indigo-700 p-3 rounded-xl">
              <CircleDollarSign size={22} />
            </div>
            <h3 class="font-semibold text-lg text-slate-800">
              Quiero pagar una multa
            </h3>
          </div>
          <p class="text-slate-600 text-sm mb-5">
            Pagá online de forma segura con los medios habilitados.
          </p>
          <span class="text-indigo-700 font-semibold group-hover:underline">
            Ir al pago →
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Cómo funciona -->
  <section class="bg-slate-100 py-20 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-slate-800 mb-10">
        ¿Cómo resolver una multa?
      </h2>

      <div class="grid gap-7 md:grid-cols-3">
        <div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200">
          <div class="text-3xl mb-3">1️⃣</div>
          <h3 class="font-semibold mb-2 text-slate-800">
            Consultá tu infracción
          </h3>
          <p class="text-sm text-slate-600">
            Ingresá tu dominio o datos personales y verificá el estado de tu
            multa.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200">
          <div class="text-3xl mb-3">2️⃣</div>
          <h3 class="font-semibold mb-2 text-slate-800">
            Elegí cómo continuar
          </h3>
          <p class="text-sm text-slate-600">
            Podés pagarla, presentar descargo o solicitar información adicional.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200">
          <div class="text-3xl mb-3">3️⃣</div>
          <h3 class="font-semibold mb-2 text-slate-800">Resolvé sin filas</h3>
          <p class="text-sm text-slate-600">
            Completá todo online o acercate solo si es necesario.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Qué necesitás llevar / saber -->
  <section class="bg-white py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-bold text-slate-800 text-center mb-3">
        ¿Qué necesitás para resolver una multa?
      </h2>
      <p class="text-center text-slate-500 mb-12">
        Te dejamos lo principal para evitar demoras o viajes innecesarios
      </p>

      <div class="grid gap-8 md:grid-cols-3">
        <!-- Documentación -->
        <div
          class="bg-slate-50 rounded-2xl p-7 shadow-sm border border-slate-200"
        >
          <div class="flex items-center gap-3 mb-4 text-blue-700">
            <ClipboardCheck size={22} />
            <h3 class="font-semibold text-slate-800">Documentación</h3>
          </div>
          <ul class="space-y-2 text-sm text-slate-700">
            <li>✔️ DNI del infractor</li>
            <li>✔️ Cédula del vehículo (verde o azul)</li>
            <li>✔️ Acta o número de infracción (si lo tenés)</li>
            <li>✔️ Poder o autorización si realiza el trámite un tercero</li>
          </ul>
        </div>

        <!-- Pagos -->
        <div
          class="bg-slate-50 rounded-2xl p-7 shadow-sm border border-slate-200"
        >
          <div class="flex items-center gap-3 mb-4 text-emerald-700">
            <CircleDollarSign size={22} />
            <h3 class="font-semibold text-slate-800">Pagos</h3>
          </div>
          <ul class="space-y-2 text-sm text-slate-700">
            <li>✔️ Medios habilitados: credito, débito o efectivo</li>
            <li>✔️ El monto se actualiza automáticamente</li>
            <li>✔️ Se emite comprobante oficial</li>
            <li>✔️ Podés pagar online o presencialmente</li>
          </ul>
        </div>

        <!-- Plazos -->
        <div
          class="bg-slate-50 rounded-2xl p-7 shadow-sm border border-slate-200"
        >
          <div class="flex items-center gap-3 mb-4 text-indigo-700">
            <Clock size={22} />
            <h3 class="font-semibold text-slate-800">Plazos</h3>
          </div>
          <ul class="space-y-2 text-sm text-slate-700">
            <li>✔️ El pago voluntario suele tener descuento</li>
            <li>✔️ Vencido el plazo, el monto se actualiza</li>
            <li>✔️ Podés presentar descargo antes de pagar</li>
            <li>✔️ Algunas faltas requieren resolución judicial previa</li>
          </ul>
        </div>
      </div>

      <div
        class="mt-10 bg-blue-50 border border-blue-100 rounded-2xl p-6 text-sm text-slate-700 max-w-6xl mx-auto"
      >
        💡 <strong>Importante:</strong> Siempre se recomienda consultar tu multa online
        antes de acercarte para confirmar estado, monto actualizado y documentación
        necesaria.
      </div>
    </div>
  </section>

  <!-- Info institucional -->
  <section id="atencion" class="bg-slate-50 py-20 px-4">
    <div class="max-w-6xl mx-auto grid gap-12 md:grid-cols-2 items-center">
      <div>
        <h2 class="text-2xl font-bold text-slate-800 mb-4">
          ¿Qué es el Juzgado de Faltas?
        </h2>
        <p class="text-slate-700 mb-4 leading-relaxed">
          Es el organismo encargado de juzgar infracciones a normas de tránsito
          y ordenanzas municipales, garantizando el derecho a defensa y el
          debido proceso.
        </p>
        <p class="text-slate-700 leading-relaxed">
          Desde este portal podés informarte, iniciar trámites y acceder a los
          servicios digitales sin necesidad de acercarte presencialmente.
        </p>

        <div class="mt-6 grid gap-3 sm:grid-cols-2 text-sm text-slate-700">
          <div class="flex items-center gap-2">✅ Trámites simples</div>
          <div class="flex items-center gap-2">✅ Atención clara</div>
          <div class="flex items-center gap-2">✅ Información oficial</div>
          <div class="flex items-center gap-2">✅ Sin filas innecesarias</div>
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow-sm p-7 border border-slate-200">
        <h3 class="font-semibold text-slate-800 mb-4 flex items-center gap-2">
          <MapPin size={18} /> Atención presencial
        </h3>

        <div class="space-y-3 text-sm text-slate-700">
          <p>
            <strong>Dirección:</strong><br />
            Maipú Norte 550
          </p>
          <p>
            <strong>Horario:</strong><br />
            Lunes a Sábado · 08:00 a 16:00 hs<br />
            Domingo · 08:00 a 12:00 hs
          </p>
        </div>

        <div
          class="mt-4 bg-slate-50 rounded-xl p-4 text-sm text-slate-600 border"
        >
          💡 Podés iniciar todo online antes de acercarte, para evitar esperas.
        </div>
      </div>
    </div>
  </section>

  <!-- Preguntas frecuentes -->
  <section class="bg-white py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-bold text-center mb-10">Preguntas frecuentes</h2>

      <div class="space-y-4 max-w-6xl mx-auto">
        <details
          class="bg-slate-50 p-6 rounded-xl shadow-sm border border-slate-200"
        >
          <summary class="font-semibold cursor-pointer text-slate-800">
            ¿Puedo pagar una multa vencida?
          </summary>
          <p class="mt-3 text-sm text-slate-600">
            Sí. El sistema mostrará automáticamente el monto actualizado y los
            medios de pago disponibles.
          </p>
        </details>

        <details
          class="bg-slate-50 p-6 rounded-xl shadow-sm border border-slate-200"
        >
          <summary class="font-semibold cursor-pointer text-slate-800">
            ¿Qué hago si no estoy de acuerdo con una multa?
          </summary>
          <p class="mt-3 text-sm text-slate-600">
            Podés presentar un descargo antes de realizar cualquier pago desde
            la sección de información.
          </p>
        </details>

        <details
          class="bg-slate-50 p-6 rounded-xl shadow-sm border border-slate-200"
        >
          <summary class="font-semibold cursor-pointer text-slate-800">
            ¿Necesito ir presencialmente?
          </summary>
          <p class="mt-3 text-sm text-slate-600">
            En la mayoría de los casos no. Todo puede iniciarse online desde
            este portal.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-slate-50 py-20 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <div
        class="bg-linear-to-r from-slate-100 to-blue-100 rounded-2xl p-10 shadow-sm"
      >
        <span
          class="inline-flex items-center gap-2 bg-white px-4 py-1.5 rounded-full text-sm text-slate-700 shadow mb-4"
        >
          ¿Tenés dudas?
        </span>

        <h3 class="text-2xl font-bold text-slate-800 mb-3">
          Te ayudamos a empezar
        </h3>
        <p class="text-slate-700 mb-6 max-w-xl mx-auto leading-relaxed">
          Si recibiste una multa o no sabés qué trámite corresponde, entrá a la
          sección de información y te guiamos paso a paso.
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a
            href="https://multasinfojuzgado.netlify.app/"
            target="_blank"
            rel="noreferrer"
            class="inline-block bg-blue-700 hover:bg-blue-800 transition text-white font-semibold px-7 py-3 rounded-lg shadow"
          >
            Ver información sobre multas
          </a>

          <a
            href="https://pagosonlinejuzgado.netlify.app/"
            target="_blank"
            rel="noreferrer"
            class="inline-block border border-blue-700 text-blue-700 hover:bg-blue-50 transition font-semibold px-7 py-3 rounded-lg"
          >
            Ir directo a pagar
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
