---
import Layout from "../layouts/MainLayout.astro";
import { FileText, CircleDollarSign, HelpCircle } from "@lucide/astro";
---

<Layout title="Juzgado de Faltas Municipal | Catamarca">
  <!-- Barra rápida -->
  <section class="bg-blue-50 border-b border-blue-100">
    <div
      class="max-w-7xl mx-auto px-4 py-2 flex flex-wrap gap-4 justify-center text-sm font-medium"
    >
      <a
        href="https://multasinfojuzgado.netlify.app/"
        target="_blank"
        rel="noreferrer"
        class="text-blue-700 hover:underline"
      >
        🚗 Multas
      </a>
      <a
        href="https://libredeuda.apps.cc.gob.ar/"
        target="_blank"
        rel="noreferrer"
        class="text-emerald-700 hover:underline"
      >
        📄 Libre deuda
      </a>
      <a
        href="https://pagosonlinejuzgado.netlify.app/"
        target="_blank"
        rel="noreferrer"
        class="text-indigo-700 hover:underline"
      >
        💳 Pagos
      </a>
      <a href="#atencion" class="text-slate-700 hover:underline">
        🕒 Horarios
      </a>
    </div>
  </section>

  <!-- Hero -->
  <section
    class="bg-linear-to-r from-slate-800 via-blue-900 to-indigo-900 text-white"
  >
    <div class="max-w-7xl mx-auto px-6 py-18 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">
        Juzgado de Faltas Municipal
      </h1>
      <p class="text-lg md:text-xl text-white/85 max-w-2xl mx-auto mb-6">
        Resolvé tus trámites, multas y consultas de forma simple, clara y sin
        complicaciones.
      </p>

      <div class="flex justify-center gap-3 flex-wrap">
        <span class="bg-white/10 backdrop-blur px-5 py-2 rounded-full text-sm">
          ✔️ Sin filas
        </span>
        <span class="bg-white/10 backdrop-blur px-5 py-2 rounded-full text-sm">
          ✔️ 100% online
        </span>
        <span class="bg-white/10 backdrop-blur px-5 py-2 rounded-full text-sm">
          ✔️ Oficial
        </span>
      </div>
    </div>
  </section>

  <!-- Accesos principales -->
  <section class="bg-white py-18 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-slate-800 text-center mb-3">
        ¿Qué necesitás hacer hoy?
      </h2>
      <p class="text-center text-slate-500 mb-12">
        Accedé rápido a los trámites más usados del Juzgado de Faltas
      </p>

      <div class="grid gap-7 md:grid-cols-3">
        <!-- Multas -->
        <a
          href="https://multasinfojuzgado.netlify.app/"
          target="_blank"
          rel="noreferrer"
          class="group bg-slate-50 rounded-2xl p-7 shadow-sm hover:shadow-md transition hover:-translate-y-1 border border-slate-200"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="bg-blue-100 text-blue-700 p-3 rounded-xl">
              <HelpCircle size={22} />
            </div>
            <h3 class="font-semibold text-lg text-slate-800">
              Tengo una multa
            </h3>
          </div>
          <p class="text-slate-600 text-sm mb-5">
            Te explicamos qué significa, qué opciones tenés y cómo seguir paso a
            paso.
          </p>
          <span class="text-blue-700 font-semibold group-hover:underline">
            Ver información →
          </span>
        </a>

        <!-- Libre deuda -->
        <a
          href="https://libredeuda.apps.cc.gob.ar/"
          target="_blank"
          rel="noreferrer"
          class="group bg-slate-50 rounded-2xl p-7 shadow-sm hover:shadow-md transition hover:-translate-y-1 border border-slate-200"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="bg-emerald-100 text-emerald-700 p-3 rounded-xl">
              <FileText size={22} />
            </div>
            <h3 class="font-semibold text-lg text-slate-800">
              Necesito libre deuda
            </h3>
          </div>
          <p class="text-slate-600 text-sm mb-5">
            Solicitá tu certificado de libre deuda en pocos minutos desde acá.
          </p>
          <span class="text-emerald-700 font-semibold group-hover:underline">
            Solicitar →
          </span>
        </a>

        <!-- Pagos -->
        <a
          href="https://pagosonlinejuzgado.netlify.app/"
          target="_blank"
          rel="noreferrer"
          class="group bg-slate-50 rounded-2xl p-7 shadow-sm hover:shadow-md transition hover:-translate-y-1 border border-slate-200"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="bg-indigo-100 text-indigo-700 p-3 rounded-xl">
              <CircleDollarSign size={22} />
            </div>
            <h3 class="font-semibold text-lg text-slate-800">
              Quiero pagar una multa
            </h3>
          </div>
          <p class="text-slate-600 text-sm mb-5">
            Pagá de forma online, rápida y segura con los medios habilitados.
          </p>
          <span class="text-indigo-700 font-semibold group-hover:underline">
            Ir al pago →
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Paso a paso -->
  <section class="bg-slate-100 py-18 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-slate-800 mb-10">
        ¿Cómo resolver una multa?
      </h2>

      <div class="grid gap-7 md:grid-cols-3">
        <div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200">
          <div class="text-3xl mb-3">1️⃣</div>
          <h3 class="font-semibold mb-2 text-slate-800">Consultá tu multa</h3>
          <p class="text-sm text-slate-600">
            Ingresá tus datos y verificá el estado de tu infracción.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200">
          <div class="text-3xl mb-3">2️⃣</div>
          <h3 class="font-semibold mb-2 text-slate-800">Elegí cómo seguir</h3>
          <p class="text-sm text-slate-600">
            Podés pagarla, presentar descargo o solicitar más información.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200">
          <div class="text-3xl mb-3">3️⃣</div>
          <h3 class="font-semibold mb-2 text-slate-800">Resolvé online</h3>
          <p class="text-sm text-slate-600">
            Completá todo desde tu casa sin hacer filas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Info institucional -->
  <section id="atencion" class="bg-white py-18 px-4">
    <div class="max-w-6xl mx-auto grid gap-12 md:grid-cols-2 items-center">
      <div>
        <h2 class="text-2xl font-bold text-slate-800 mb-4">
          ¿Qué es el Juzgado de Faltas?
        </h2>
        <p class="text-slate-700 mb-4 leading-relaxed">
          El Juzgado de Faltas Municipal es el organismo encargado de resolver
          infracciones a las normas de tránsito y ordenanzas municipales,
          garantizando el derecho a defensa y el debido proceso de cada
          ciudadano.
        </p>
        <p class="text-slate-700 leading-relaxed">
          Desde este portal podés informarte, iniciar trámites y acceder a los
          servicios digitales más importantes sin necesidad de acercarte
          presencialmente, ahorrando tiempo y evitando esperas innecesarias.
        </p>

        <div class="mt-6 flex flex-col sm:flex-row gap-4">
          <div class="flex items-center gap-3 text-sm text-slate-700">
            ✅ Atención clara y sin tecnicismos
          </div>
          <div class="flex items-center gap-3 text-sm text-slate-700">
            ✅ Trámites simples y accesibles
          </div>
          <div class="flex items-center gap-3 text-sm text-slate-700">
            ✅ Información oficial y confiable
          </div>
        </div>
      </div>

      <div
        class="bg-slate-50 rounded-2xl shadow-sm p-7 border border-slate-200"
      >
        <h3 class="font-semibold text-slate-800 mb-3 flex items-center gap-2">
          📍 Atención presencial
        </h3>

        <div class="space-y-2 text-sm text-slate-700">
          <p>
            <strong>Dirección:</strong> Maipú Norte 550
          </p>
          <p>
            <strong>Horario:</strong><br />
            Lunes a Sábado · 08:00 a 16:00 hs<br />
            Domingo · 08:00 a 12:00 hs
          </p>
        </div>

        <div class="mt-4 bg-white rounded-xl p-4 text-sm text-slate-600 border">
          💡 Si tenés una multa o consulta, podés iniciar todo online desde este
          portal antes de acercarte.
        </div>
      </div>
    </div>
  </section>

  <!-- Preguntas frecuentes -->
  <section class="bg-slate-50 py-18 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-center mb-10">Preguntas frecuentes</h2>

      <div class="space-y-4">
        <details
          class="bg-white p-6 rounded-xl shadow-sm border border-slate-200"
        >
          <summary class="font-semibold cursor-pointer text-slate-800">
            ¿Puedo pagar una multa vencida?
          </summary>
          <p class="mt-3 text-sm text-slate-600">
            Sí. El sistema te mostrará automáticamente el monto actualizado y
            los medios de pago disponibles.
          </p>
        </details>

        <details
          class="bg-white p-6 rounded-xl shadow-sm border border-slate-200"
        >
          <summary class="font-semibold cursor-pointer text-slate-800">
            ¿Qué hago si no estoy de acuerdo con una multa?
          </summary>
          <p class="mt-3 text-sm text-slate-600">
            Podés iniciar un descargo desde la sección de información antes de
            realizar cualquier pago.
          </p>
        </details>

        <details
          class="bg-white p-6 rounded-xl shadow-sm border border-slate-200"
        >
          <summary class="font-semibold cursor-pointer text-slate-800">
            ¿Necesito ir presencialmente?
          </summary>
          <p class="mt-3 text-sm text-slate-600">
            En la mayoría de los casos no. Todo puede iniciarse desde este
            portal de manera digital.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-white py-18 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <div
        class="bg-linear-to-r from-slate-100 to-blue-100 rounded-2xl p-10 shadow-sm"
      >
        <div
          class="inline-flex items-center gap-2 bg-white px-4 py-1.5 rounded-full text-sm text-slate-700 shadow mb-4"
        >
          ¿Tenés dudas?
        </div>

        <h3 class="text-2xl font-bold text-slate-800 mb-3">
          No sabés por dónde empezar
        </h3>
        <p class="text-slate-700 mb-6 max-w-xl mx-auto leading-relaxed">
          Si recibiste una multa o no estás seguro qué trámite corresponde,
          entrá a la sección de información y te guiamos paso a paso con
          explicaciones claras.
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a
            href="https://multasinfojuzgado.netlify.app/"
            target="_blank"
            rel="noreferrer"
            class="inline-block bg-blue-700 hover:bg-blue-800 transition text-white font-semibold px-7 py-3 rounded-lg shadow"
          >
            Ver información sobre multas
          </a>

          <a
            href="https://pagosonlinejuzgado.netlify.app/"
            target="_blank"
            rel="noreferrer"
            class="inline-block border border-blue-700 text-blue-700 hover:bg-blue-50 transition font-semibold px-7 py-3 rounded-lg"
          >
            Ir directo a pagar
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
