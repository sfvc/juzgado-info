---
import Layout from "../layouts/MainLayout.astro";
import {
  FileText,
  CircleDollarSign,
  HelpCircle,
  Clock,
  MapPin,
  ClipboardCheck,
  Car,
  Building2,
  Utensils,
  SearchCheck,
  X,
} from "@lucide/astro";
---

<Layout title="Juzgado de Faltas Municipal | Catamarca">
  <!-- Barra rápida -->
  <section class="bg-blue-50 border-b border-blue-100">
    <div
      class="max-w-7xl mx-auto px-4 py-2 flex flex-wrap gap-4 justify-center text-sm font-medium"
    >
      <a
        href="https://multasinfojuzgado.netlify.app/"
        target="_blank"
        rel="noreferrer"
        class="text-blue-700 hover:underline"
      >
        🚗 Consultar multas
      </a>
      <a
        href="https://libredeuda.apps.cc.gob.ar/"
        target="_blank"
        rel="noreferrer"
        class="text-emerald-700 hover:underline"
      >
        📄 Libre deuda
      </a>
      <a
        href="https://pagosonlinejuzgado.netlify.app/"
        target="_blank"
        rel="noreferrer"
        class="text-indigo-700 hover:underline"
      >
        💳 Pagar multas
      </a>
      <a href="#atencion" class="text-slate-700 hover:underline">
        🕒 Atención presencial
      </a>
    </div>
  </section>

  <!-- Hero -->
  <section
    class="bg-linear-to-r from-slate-800 via-blue-900 to-indigo-900 text-white"
  >
    <div class="max-w-7xl mx-auto px-6 py-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">
        Juzgado de Faltas Municipal
      </h1>
      <p class="text-lg md:text-xl text-white/85 max-w-2xl mx-auto mb-6">
        Consultá, resolvé y pagá tus infracciones de forma rápida, clara y sin
        hacer filas.
      </p>

      <div class="flex justify-center gap-3 flex-wrap">
        <span class="bg-white/10 backdrop-blur px-5 py-2 rounded-full text-sm"
          >✔️ 100% online</span
        >
        <span class="bg-white/10 backdrop-blur px-5 py-2 rounded-full text-sm"
          >✔️ Oficial</span
        >
        <span class="bg-white/10 backdrop-blur px-5 py-2 rounded-full text-sm"
          >✔️ Sin trámites innecesarios</span
        >
      </div>
    </div>
  </section>

  <!-- Tipos de Actas -->
  <section class="bg-slate-100 py-14 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center text-slate-800 mb-3">
        Tipos de Actas y Procedimientos
      </h2>
      <p class="text-center text-slate-500 mb-10 max-w-2xl mx-auto">
        Consultá los requisitos necesarios para el pago voluntario o la
        presentación de descargo, según el tipo de acta labrada.
      </p>

      <div class="grid gap-7 md:grid-cols-4">
        <!-- Transito -->
        <button data-type="transito" class="acta-card">
          <Car size={28} />
          <span>Tránsito</span>
        </button>

        <!-- Obras -->
        <button data-type="obras" class="acta-card">
          <Building2 size={28} />
          <span>Obras Particulares</span>
        </button>

        <!-- Bromatologia -->
        <button data-type="bromatologia" class="acta-card">
          <Utensils size={28} />
          <span>Bromatología</span>
        </button>

        <!-- Inspeccion -->
        <button data-type="inspeccion" class="acta-card">
          <SearchCheck size={28} />
          <span>Inspección</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Modal -->
  <div
    id="actaModal"
    class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50 px-4"
  >
    <div
      class="bg-white rounded-2xl max-w-xl w-full p-8 relative shadow-lg animate-fade-in"
    >
      <button
        id="closeModal"
        class="cursor-pointer absolute top-4 right-4 text-slate-500 hover:text-slate-800"
      >
        <X size={22} />
      </button>

      <h3 id="modalTitle" class="text-xl font-bold mb-6 text-slate-800"></h3>

      <!-- Pago -->
      <div class="mb-6">
        <h4 class="font-semibold text-blue-700 mb-3">
          Requisitos para el Pago Voluntario <span class="text-black"
            >(40% de descuento)</span
          >
        </h4>
        <ul class="text-sm text-slate-700 space-y-2">
          <li>✔️ Fotocopia del DNI del titular</li>
        </ul>

        <div id="pagoRestriccion" class="mt-4"></div>
      </div>

      <!-- Descargo -->
      <div>
        <h4 class="font-semibold text-indigo-700 mb-3">
          Requisitos para Presentar Descargo
        </h4>
        <ul id="descargoList" class="text-sm text-slate-700 space-y-2"></ul>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const modal = document.getElementById("actaModal") as HTMLDivElement;
      const closeModal = document.getElementById(
        "closeModal",
      ) as HTMLButtonElement;
      const modalTitle = document.getElementById(
        "modalTitle",
      ) as HTMLHeadingElement;
      const descargoList = document.getElementById(
        "descargoList",
      ) as HTMLUListElement;

      const commonDescargo = `
        <li>✔️ Fotocopia del DNI del titular</li>
        <li>✔️ Nota explicando el motivo del descargo</li>
      `;

      const comercialExtra = `
        <li>✔️ Habilitación comercial correspondiente o constancia de alta en ARCA</li>
      `;

      const transitoExtra = `
        <li>✔️ Copia de la cédula del titular</li>
        <li>✔️ Copia del seguro vigente</li>
      `;

      const pagoRestriccion = document.getElementById(
        "pagoRestriccion",
      ) as HTMLDivElement;

      const restriccionTransito = `
        <div class="bg-red-50 border border-red-200 text-red-800 text-xs rounded-lg p-3">
          ⚠️ No se puede acceder al pago online si la infracción corresponde a los códigos:
          <strong>163, 164, 166, 169, 193, 194, 81</strong>.
        </div>
      `;

      const restriccionObras = `
        <div class="bg-red-50 border border-red-200 text-red-800 text-xs rounded-lg p-3">
          ⚠️ No se puede acceder al pago online si la infracción corresponde a los códigos:
          <strong>87, 88, 24</strong>.
        </div>
      `;

      const restriccionInspeccion = `
        <div class="bg-red-50 border border-red-200 text-red-800 text-xs rounded-lg p-3">
          ⚠️ No se puede acceder al pago online si la infracción corresponde a los códigos:
          <strong>24, 62, 14</strong>.
        </div>
      `;

      const restriccionBromatologia = `
        <div class="bg-red-50 border border-red-200 text-red-800 text-xs rounded-lg p-3">
          ⚠️ No se puede acceder al pago online si la infracción corresponde a los códigos:
          <strong>24, 14, 72</strong>.
        </div>
      `;

      const buttons =
        document.querySelectorAll<HTMLButtonElement>(".acta-card");

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const type = btn.dataset.type;

          if (!type) return;

          if (type === "transito") {
            modalTitle.textContent = "Acta de Infracción de Tránsito";
            descargoList.innerHTML = commonDescargo + transitoExtra;
          } else if (type === "obras") {
            modalTitle.textContent = "Acta de Obras Particulares";
            descargoList.innerHTML = commonDescargo + comercialExtra;
          } else if (type === "bromatologia") {
            modalTitle.textContent = "Acta de Bromatología";
            descargoList.innerHTML = commonDescargo + comercialExtra;
          } else {
            modalTitle.textContent = "Acta de Inspección General";
            descargoList.innerHTML = commonDescargo + comercialExtra;
          }

          pagoRestriccion.innerHTML = "";
          if (type === "transito") {
            pagoRestriccion.innerHTML = restriccionTransito;
          } else if (type === "obras") {
            pagoRestriccion.innerHTML = restriccionObras;
          } else if (type === "bromatologia") {
            pagoRestriccion.innerHTML = restriccionBromatologia;
          } else {
            pagoRestriccion.innerHTML = restriccionInspeccion;
          }

          modal.classList.remove("hidden");
          modal.classList.add("flex");
        });
      });

      closeModal.addEventListener("click", () => {
        modal.classList.add("hidden");
        modal.classList.remove("flex");
      });

      modal.addEventListener("click", (e) => {
        if (e.target === modal) {
          modal.classList.add("hidden");
          modal.classList.remove("flex");
        }
      });
    });
  </script>

  <!-- Accesos principales -->
  <section class="bg-white py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-bold text-slate-800 text-center mb-3">
        ¿Qué documentación y plazos debés tener en cuenta para resolver tu
        multa?
      </h2>
      <p class="text-center text-slate-500 mb-12">
        Accedé directamente a los trámites más usados
      </p>

      <div class="grid gap-7 md:grid-cols-3">
        <!-- Multas -->
        <a
          href="https://multasinfojuzgado.netlify.app/"
          target="_blank"
          rel="noreferrer"
          class="group bg-slate-50 rounded-2xl p-7 shadow-sm hover:shadow-md transition hover:-translate-y-1 border border-slate-200"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="bg-blue-100 text-blue-700 p-3 rounded-xl">
              <HelpCircle size={22} />
            </div>
            <h3 class="font-semibold text-lg text-slate-800">
              Tengo una multa
            </h3>
          </div>
          <p class="text-slate-600 text-sm mb-5">
            Consultá qué significa, si está vigente y qué opciones tenés para
            resolverla.
          </p>
          <span class="text-blue-700 font-semibold group-hover:underline">
            Ver información →
          </span>
        </a>

        <!-- Libre deuda -->
        <a
          href="https://libredeuda.apps.cc.gob.ar/"
          target="_blank"
          rel="noreferrer"
          class="group bg-slate-50 rounded-2xl p-7 shadow-sm hover:shadow-md transition hover:-translate-y-1 border border-slate-200"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="bg-emerald-100 text-emerald-700 p-3 rounded-xl">
              <FileText size={22} />
            </div>
            <h3 class="font-semibold text-lg text-slate-800">
              Necesito libre deuda
            </h3>
          </div>
          <p class="text-slate-600 text-sm mb-5">
            Solicitá tu certificado en minutos desde el sistema oficial.
          </p>
          <span class="text-emerald-700 font-semibold group-hover:underline">
            Solicitar →
          </span>
        </a>

        <!-- Pagos -->
        <a
          href="https://pagosonlinejuzgado.netlify.app/"
          target="_blank"
          rel="noreferrer"
          class="group bg-slate-50 rounded-2xl p-7 shadow-sm hover:shadow-md transition hover:-translate-y-1 border border-slate-200"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="bg-indigo-100 text-indigo-700 p-3 rounded-xl">
              <CircleDollarSign size={22} />
            </div>
            <h3 class="font-semibold text-lg text-slate-800">
              Quiero pagar una multa
            </h3>
          </div>
          <p class="text-slate-600 text-sm mb-5">
            Pagá online de forma segura con los medios habilitados.
          </p>
          <span class="text-indigo-700 font-semibold group-hover:underline">
            Ir al pago →
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Cómo funciona -->
  <section class="bg-slate-100 py-12 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-slate-800 mb-10">
        ¿Cómo podés consultar y resolver tu multa paso a paso?
      </h2>

      <div class="grid gap-7 md:grid-cols-3">
        <div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200">
          <div class="text-3xl mb-3">1️⃣</div>
          <h3 class="font-semibold mb-2 text-slate-800">
            Consultá tu infracción
          </h3>
          <p class="text-sm text-slate-600">
            Ingresá tu dominio o datos personales y verificá el estado de tu
            multa.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200">
          <div class="text-3xl mb-3">2️⃣</div>
          <h3 class="font-semibold mb-2 text-slate-800">
            Elegí cómo continuar
          </h3>
          <p class="text-sm text-slate-600">
            Podés pagarla, presentar descargo o solicitar información adicional.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200">
          <div class="text-3xl mb-3">3️⃣</div>
          <h3 class="font-semibold mb-2 text-slate-800">Resolvé sin filas</h3>
          <p class="text-sm text-slate-600">
            Completá todo online o acercate solo si es necesario.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Qué necesitás llevar / saber -->
  <section class="bg-white py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-bold text-slate-800 text-center mb-3">
        ¿Qué necesitás para resolver una multa?
      </h2>
      <p class="text-center text-slate-500 mb-12">
        Traé esta documentación y conocé los plazos para evitar recargos
      </p>

      <div class="grid gap-8 md:grid-cols-3">
        <!-- Documentación -->
        <div
          class="bg-slate-50 rounded-2xl p-7 shadow-sm border border-slate-200"
        >
          <div class="flex items-center gap-3 mb-4 text-blue-700">
            <ClipboardCheck size={22} />
            <h3 class="font-semibold text-slate-800">Documentación</h3>
          </div>
          <ul class="space-y-2 text-sm text-slate-700">
            <li>✔️ DNI del infractor</li>
            <li>✔️ DNI del titular del vehículo</li>
            <li>✔️ Cédula verde o título del automotor</li>
            <li>✔️ Licencia de conducir</li>
            <li>✔️ Comprobante de seguro</li>
            <li class="text-xs text-slate-500 mt-2">
              📄 Toda la documentación debe presentarse en fotocopia
            </li>
          </ul>
        </div>

        <!-- Pagos -->
        <div
          class="bg-slate-50 rounded-2xl p-7 shadow-sm border border-slate-200"
        >
          <div class="flex items-center gap-3 mb-4 text-emerald-700">
            <CircleDollarSign size={22} />
            <h3 class="font-semibold text-slate-800">Pago voluntario</h3>
          </div>
          <ul class="space-y-2 text-sm text-slate-700">
            <li>
              ✔️ Si realizás el pago dentro de los <strong>30 días</strong>,
              accedés a un <strong class="text-emerald-700"
                >40% de descuento</strong
              >
            </li>
            <li>✔️ Podés pagar online o presencialmente</li>
            <li>✔️ El sistema emite comprobante oficial</li>
            <li>
              ✔️ Luego del vencimiento se pierde el descuento y se actualiza el
              monto
            </li>
          </ul>
        </div>

        <!-- Plazos -->
        <div
          class="bg-slate-50 rounded-2xl p-7 shadow-sm border border-slate-200"
        >
          <div class="flex items-center gap-3 mb-4 text-indigo-700">
            <Clock size={22} />
            <h3 class="font-semibold text-slate-800">Descargos y recargos</h3>
          </div>
          <ul class="space-y-2 text-sm text-slate-700">
            <li>
              ✔️ Si presentás descargo, <strong>perdés el descuento</strong>
            </li>
            <li>✔️ Pasados los 30 días entra en <strong>rebeldía</strong></li>
            <li>✔️ En rebeldía se quita el descuento y se suma recargo</li>
            <li>✔️ Algunas faltas requieren resolución judicial previa</li>
          </ul>
        </div>
      </div>

      <div
        class="mt-10 bg-blue-50 border border-blue-100 rounded-2xl p-6 text-sm text-slate-700 max-w-6xl mx-auto"
      >
        💡 <strong>Recomendación:</strong> Consultá tu multa online antes de acercarte
        para confirmar estado, monto actualizado y documentación necesaria.
      </div>
    </div>
  </section>

  <!-- Info institucional -->
  <section id="atencion" class="bg-slate-50 py-12 px-4">
    <div class="max-w-6xl mx-auto grid gap-12 md:grid-cols-2 items-center">
      <div>
        <h2 class="text-2xl font-bold text-slate-800 mb-4">
          ¿Qué funciones cumple el Juzgado de Faltas Municipal?
        </h2>
        <p class="text-slate-700 mb-4 leading-relaxed">
          Es el organismo encargado de juzgar infracciones a normas de tránsito
          y ordenanzas municipales, garantizando el derecho a defensa y el
          debido proceso.
        </p>
        <p class="text-slate-700 leading-relaxed">
          Desde este portal podés informarte, iniciar trámites y acceder a los
          servicios digitales sin necesidad de acercarte presencialmente.
        </p>

        <div class="mt-6 grid gap-3 sm:grid-cols-2 text-sm text-slate-700">
          <div class="flex items-center gap-2">✅ Trámites simples</div>
          <div class="flex items-center gap-2">✅ Atención clara</div>
          <div class="flex items-center gap-2">✅ Información oficial</div>
          <div class="flex items-center gap-2">✅ Sin filas innecesarias</div>
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow-sm p-7 border border-slate-200">
        <h3 class="font-semibold text-slate-800 mb-4 flex items-center gap-2">
          <MapPin size={18} /> Atención presencial
        </h3>

        <div class="space-y-3 text-sm text-slate-700">
          <p>
            <strong>Dirección:</strong><br />
            Maipú Norte 550
          </p>
          <p>
            <strong>Horario:</strong><br />
            Lunes a Sábado · 08:00 a 16:00 hs<br />
            Domingo · 08:00 a 12:00 hs
          </p>
        </div>

        <div
          class="mt-4 bg-slate-50 rounded-xl p-4 text-sm text-slate-600 border"
        >
          💡 Podés iniciar todo online antes de acercarte, para evitar esperas.
        </div>
      </div>
    </div>
  </section>

  <!-- Preguntas frecuentes -->
  <section class="bg-white py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-bold text-center mb-10">Preguntas frecuentes</h2>

      <div class="space-y-4 max-w-6xl mx-auto">
        <details
          class="bg-slate-50 p-6 rounded-xl shadow-sm border border-slate-200"
        >
          <summary class="font-semibold cursor-pointer text-slate-800">
            ¿Cómo puedo pagar una multa si ya está vencida?
          </summary>
          <p class="mt-3 text-sm text-slate-600">
            Podés pagarla igualmente. El sistema mostrará automáticamente el
            monto actualizado con los recargos correspondientes y los medios de
            pago disponibles.
          </p>
        </details>

        <details
          class="bg-slate-50 p-6 rounded-xl shadow-sm border border-slate-200"
        >
          <summary class="font-semibold cursor-pointer text-slate-800">
            ¿Qué debo hacer si no estoy de acuerdo con la multa recibida?
          </summary>
          <p class="mt-3 text-sm text-slate-600">
            Podés presentar un descargo antes de realizar cualquier pago. Para
            eso, reuní la documentación correspondiente y seguí los requisitos
            indicados según el tipo de acta.
          </p>
        </details>

        <details
          class="bg-slate-50 p-6 rounded-xl shadow-sm border border-slate-200"
        >
          <summary class="font-semibold cursor-pointer text-slate-800">
            ¿Es obligatorio asistir personalmente al Juzgado?
          </summary>
          <p class="mt-3 text-sm text-slate-600">
            En la mayoría de los casos no es obligatorio. Podés iniciar y
            resolver el trámite online desde el sistema de pagos o consulta.
            Solo deberás asistir si el caso requiere resolución presencial o tu vehículo fue retenido.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-slate-50 py-12 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <div
        class="bg-linear-to-r from-slate-100 to-blue-100 rounded-2xl p-10 shadow-sm"
      >
        <span
          class="inline-flex items-center gap-2 bg-white px-4 py-1.5 rounded-full text-sm text-slate-700 shadow mb-4"
        >
          ¿Tenés dudas?
        </span>

        <h3 class="text-2xl font-bold text-slate-800 mb-3">
          Te guiamos para que puedas resolverlo fácilmente
        </h3>
        <p class="text-slate-700 mb-6 max-w-xl mx-auto leading-relaxed">
          Si recibiste una multa o no sabés qué trámite corresponde, entrá a la
          sección de información y te guiamos paso a paso.
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a
            href="https://multasinfojuzgado.netlify.app/"
            target="_blank"
            rel="noreferrer"
            class="inline-block bg-blue-700 hover:bg-blue-800 transition text-white font-semibold px-7 py-3 rounded-lg shadow"
          >
            Ver información sobre multas
          </a>

          <a
            href="https://pagosonlinejuzgado.netlify.app/"
            target="_blank"
            rel="noreferrer"
            class="inline-block border border-blue-700 text-blue-700 hover:bg-blue-50 transition font-semibold px-7 py-3 rounded-lg"
          >
            Ir directo a pagar
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
