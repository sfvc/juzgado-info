---
import Layout from "../layouts/MainLayout.astro";
import {
  FileText,
  CircleDollarSign,
  HelpCircle,
  Clock,
  MapPin,
  ClipboardCheck,
  Car,
  Building2,
  Utensils,
  SearchCheck,
  X,
  FileCheckCorner,
} from "@lucide/astro";
---

<Layout title="Juzgado de Faltas Municipal | Catamarca">
  <!-- Hero -->
  <section class="bg-[#0f4c94] text-white">
    <div class="max-w-7xl mx-auto px-6 py-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">
        Juzgado de Faltas Municipal
      </h1>
      <p class="text-lg md:text-xl text-white/85 max-w-2xl mx-auto mb-6">
        Consultá, resolvé y pagá tus infracciones de forma rápida, clara y sin
        hacer filas.
      </p>

      <div class="flex justify-center gap-3 flex-wrap">
        <span class="bg-white/10 backdrop-blur px-5 py-2 rounded-full text-sm"
          >100% online</span
        >
        <span class="bg-white/10 backdrop-blur px-5 py-2 rounded-full text-sm"
          >Oficial</span
        >
        <span class="bg-white/10 backdrop-blur px-5 py-2 rounded-full text-sm"
          >Sin trámites innecesarios</span
        >
      </div>
    </div>
  </section>

  <!-- Tipos de Actas -->
  <section class="bg-slate-100 py-8 px-4">
    <div
      class="bg-blue-50 border border-blue-200 text-blue-900 text-sm rounded-lg px-4 py-4 mb-6 max-w-6xl mx-auto"
    >
      <strong class="text-green-900">Trámite online:</strong> generalmente no requiere
      presentar documentación.<br />
      <strong class="text-amber-900">Trámite presencial:</strong> se debe asistir
      con documentación original y copia.
    </div>

    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center text-slate-800 mb-3">
        Tramites que se pueden realizar
      </h2>
      <p class="text-center text-slate-500 mb-10 max-w-2xl mx-auto">
        Consultá los requisitos necesarios para el pago voluntario o la
        presentación de descargo, según el tipo de acta labrada.
      </p>

      <div class="grid gap-7 md:grid-cols-3">
        <!-- Transito -->
        <button data-type="transito" class="acta-card">
          <Car size={28} />
          <span>TRÁNSITO</span>
        </button>

        <!-- Obras -->
        <button data-type="obras" class="acta-card">
          <Building2 size={28} />
          <span>OBRAS PARTICULARES</span>
        </button>

        <!-- Bromatologia -->
        <button data-type="bromatologia" class="acta-card">
          <Utensils size={28} />
          <span>BROMATOLOGÍA</span>
        </button>

        <!-- Inspeccion -->
        <button data-type="inspeccion" class="acta-card">
          <SearchCheck size={28} />
          <span>INSPECCIÓN / POLICIA AMBIENTAL</span>
        </button>

        <!-- Libre Deuda -->
        <button data-type="libre_deuda" class="acta-card">
          <FileCheckCorner size={28} />
          <span>LIBRE DEUDA</span>
        </button>

        <!-- Descargo -->
        <button data-type="descargo_online" class="acta-card">
          <FileText size={28} />
          <span>DESCARGO ONLINE</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Modal -->
  <div
    id="actaModal"
    class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50 px-4"
  >
    <div
      class="bg-white rounded-2xl max-w-xl w-full p-8 relative shadow-lg animate-fade-in max-h-[90vh] overflow-y-auto"
    >
      <button
        id="closeModal"
        class="cursor-pointer absolute top-4 right-4 text-slate-500 hover:text-slate-800"
      >
        <X size={22} />
      </button>

      <h3 id="modalTitle" class="text-xl font-bold mb-6 text-slate-800"></h3>

      <div id="multasContent">
        <div class="mb-3">
          <h4 class="font-semibold text-emerald-700 mb-3">
            Pago Voluntario Online
          </h4>

          <div
            class="bg-emerald-50 border border-emerald-200 rounded-lg p-3 text-sm text-emerald-900 mb-4"
          >
            ✔ En la mayoría de los casos no necesitás presentar documentación.<br
            />
            ✔ Solo debés ingresar al sistema y realizar el pago de la infracción.
          </div>

          <div class="mt-3">
            <a
              href="https://pagosonlinejuzgado.netlify.app/"
              target="_blank"
              class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 transition text-white text-sm font-semibold px-5 py-2.5 rounded-lg"
            >
              Ir al Sistema de Pago Online
            </a>
          </div>

          <hr class="my-6" />

          <h4 class="font-semibold text-blue-700">
            Pago Voluntario Presencial
          </h4>

          <p class="font-semibold text-green-700 mb-3 mt-1">
            (40 % de descuento) solo podrá tener este beneficio en casos de no
            poseer multas anteriores
          </p>

          <ul class="text-sm text-slate-700 space-y-2">
            <li>✔ Fotocopia del DNI del titular</li>
            <li>✔ Fotocopia del DNI del infractor</li>
            <li>✔ Presentarse dentro de los 30 días desde la notificación</li>
          </ul>
          <div id="pagoRestriccion" class="mt-3"></div>
        </div>

        <div>
          <h4 class="font-semibold text-indigo-700 mb-3">
            Requisitos para el Descargo Presencial
          </h4>
          <ul id="descargoList" class="text-sm text-slate-700 space-y-2"></ul>
          <div
            class="mt-4 bg-amber-50 border border-amber-200 text-amber-900 text-xs rounded-lg p-4"
          >
            <strong>⚠️ Importante:</strong> Este trámite es presencial por Mesa de
            Entrada del Juzgado de Faltas según fecha de labrado:
            <br /><br />
            📅 Del 1° al 15 → Juzgado de Faltas N° 1
            <br />
            📅 Del 16 al 31 → Juzgado de Faltas N° 2
            <br /><br />
            Deben concurrir con documentación original y copia. Es obligatoria la
            presencia del infractor y del titular.
            <br /><br />
            🕒 Atención: Lunes a Viernes de 08:00 a 15:00 hs.
          </div>
        </div>
      </div>

      <div id="libreDeudaContent" class="hidden">
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 mb-6">
          <p class="text-slate-700 leading-relaxed">
            Para solicitar el <strong>Certificado de Libre Deuda</strong>, el
            contribuyente
            <span class="text-blue-800 font-bold"
              >no debe registrar multas pendientes de pago</span
            >
            ni procesos judiciales abiertos en este Juzgado de Faltas.
          </p>
        </div>

        <div class="space-y-4">
          <a
            href="https://libredeuda.apps.cc.gob.ar/"
            target="_blank"
            rel="noreferrer"
            class="flex items-center justify-center gap-2 bg-blue-700 hover:bg-blue-800 transition text-white font-semibold px-6 py-3 rounded-xl w-full shadow-sm"
          >
            <FileCheckCorner size={20} />
            Ir al Sistema de Libre Deuda
          </a>
        </div>
      </div>

      <div id="descargoOnlineContent" class="hidden">
        <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-5 mb-6">
          <p class="text-slate-700 leading-relaxed">
            Podés presentar un <strong>descargo online</strong> sin necesidad de asistir
            al Juzgado.
          </p>

          <ul class="mt-3 text-sm text-slate-700 space-y-2">
            <li>
              ✔ Solo necesitás redactar la <strong>nota de descargo</strong>
            </li>
            <li>✔ No es obligatorio adjuntar documentación</li>
            <li>✔ Podés seguir el estado del trámite desde el sistema</li>
          </ul>
        </div>

        <a
          href="https://descargosjuzgado.netlify.app/"
          target="_blank"
          class="flex items-center justify-center gap-2 bg-indigo-700 hover:bg-indigo-800 transition text-white font-semibold px-6 py-3 rounded-xl w-full shadow-sm"
        >
          <FileText size={20} />
          Ir al Sistema de Descargos
        </a>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const modal = document.getElementById("actaModal") as HTMLDivElement;
      const closeModal = document.getElementById(
        "closeModal",
      ) as HTMLButtonElement;
      const modalTitle = document.getElementById(
        "modalTitle",
      ) as HTMLHeadingElement;
      const descargoList = document.getElementById(
        "descargoList",
      ) as HTMLUListElement;
      const pagoRestriccion = document.getElementById(
        "pagoRestriccion",
      ) as HTMLDivElement;
      const multasContent = document.getElementById(
        "multasContent",
      ) as HTMLDivElement;
      const libreDeudaContent = document.getElementById(
        "libreDeudaContent",
      ) as HTMLDivElement;
      const descargoOnlineContent = document.getElementById(
        "descargoOnlineContent",
      ) as HTMLDivElement;

      const commonDescargo = `
      <li>✔ Fotocopia del DNI del titular</li>
      <li>✔ Fotocopia del DNI del infractor</li>
      <li>✔ Nota explicando el motivo del descargo</li>
      `;

      const comercialExtra = `<li>✔ Habilitación comercial correspondiente o constancia de alta en ARCA</li>`;

      const transitoExtra = `
      <li>✔ Fotocopia de la licencia de conducir del infractor</li>
      <li>✔ Fotocopia de la cédula del infractor</li>
      <li>✔ Fotocopia del seguro vigente</li>
    `;

      // const restriccionTransito = `<div class="bg-red-50 border border-red-200 text-red-800 text-xs rounded-lg p-3">⚠️ No se puede acceder al pago online si la infracción corresponde a <strong>retención de vehículo</strong> o los códigos: <strong>163, 164, 166, 169, 193, 194, 81</strong>.</div>`;
      // const restriccionObras = `<div class="bg-red-50 border border-red-200 text-red-800 text-xs rounded-lg p-3">⚠️ No se puede acceder al pago online si la infracción corresponde a los códigos: <strong>87, 88, 24</strong>.</div>`;
      // const restriccionInspeccion = `<div class="bg-red-50 border border-red-200 text-red-800 text-xs rounded-lg p-3">⚠️ No se puede acceder al pago online si la infracción corresponde a los códigos: <strong>24, 62, 14</strong>.</div>`;
      // const restriccionBromatologia = `<div class="bg-red-50 border border-red-200 text-red-800 text-xs rounded-lg p-3">⚠️ No se puede acceder al pago online si la infracción corresponde a los códigos: <strong>24, 14, 72</strong>.</div>`;

      const buttons =
        document.querySelectorAll<HTMLButtonElement>(".acta-card");

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const type = btn.dataset.type;
          if (!type) return;

          multasContent.classList.add("hidden");
          libreDeudaContent.classList.add("hidden");
          descargoOnlineContent.classList.add("hidden");

          if (type === "descargo_online") {
            modalTitle.textContent = "Presentar Descargo";
            descargoOnlineContent.classList.remove("hidden");
          } else if (type === "libre_deuda") {
            modalTitle.textContent = "Solicitud de Libre Deuda";
            libreDeudaContent.classList.remove("hidden");
          } else {
            modalTitle.textContent = "Información del Acta";
            multasContent.classList.remove("hidden");

            if (type === "transito") {
              modalTitle.textContent = "Acta de Infracción de Tránsito";
              descargoList.innerHTML = commonDescargo + transitoExtra;
              // pagoRestriccion.innerHTML = restriccionTransito;
            } else if (type === "obras") {
              modalTitle.textContent = "Acta de Obras Particulares";
              descargoList.innerHTML = commonDescargo + comercialExtra;
              // pagoRestriccion.innerHTML = restriccionObras;
            } else if (type === "bromatologia") {
              modalTitle.textContent = "Acta de Bromatología";
              descargoList.innerHTML = commonDescargo + comercialExtra;
              // pagoRestriccion.innerHTML = restriccionBromatologia;
            } else if (type === "inspeccion") {
              modalTitle.textContent = "Acta de Inspección General";
              descargoList.innerHTML = commonDescargo + comercialExtra;
              // pagoRestriccion.innerHTML = restriccionInspeccion;
            }
          }

          modal.classList.remove("hidden");
          modal.classList.add("flex");

          document.body.style.overflow = "hidden";
        });
      });

      const closeAction = () => {
        modal.classList.add("hidden");
        modal.classList.remove("flex");

        document.body.style.overflow = "";
      };

      closeModal.addEventListener("click", closeAction);
      modal.addEventListener("click", (e) => {
        if (e.target === modal) closeAction();
      });
    });
  </script>

  <!-- Qué necesitás llevar / saber -->
  <section class="bg-white py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-bold text-slate-800 text-center mb-3">
        ¿Qué necesitás para resolver una multa?
      </h2>
      <p class="text-center text-slate-500 mb-12">
        Traé esta documentación y conocé los plazos para evitar recargos
      </p>

      <div class="grid gap-8 md:grid-cols-3">
        <!-- Documentación -->
        <div
          class="bg-slate-50 rounded-2xl p-7 shadow-sm border border-slate-200"
        >
          <div class="flex items-center gap-3 mb-4 text-blue-700">
            <ClipboardCheck size={22} />
            <h3 class="font-semibold text-slate-800">Documentación</h3>
          </div>
          <ul class="space-y-2 text-sm text-slate-700">
            <li>✔ DNI del infractor</li>
            <li>✔ DNI del titular del vehículo</li>
            <li>✔ Cédula verde o título del automotor</li>
            <li>✔ Licencia de conducir</li>
            <li>✔ Comprobante de seguro</li>
            <li class="text-xs text-slate-500 mt-2">
              📄 Toda la documentación debe presentarse en fotocopia
            </li>
          </ul>
        </div>

        <!-- Pagos -->
        <div
          class="bg-slate-50 rounded-2xl p-7 shadow-sm border border-slate-200"
        >
          <div class="flex items-center gap-3 mb-4 text-emerald-700">
            <CircleDollarSign size={22} />
            <h3 class="font-semibold text-slate-800">Pago voluntario</h3>
          </div>
          <ul class="space-y-2 text-sm text-slate-700">
            <li>
              ✔ Si realizás el pago dentro de los <strong>30 días</strong>,
              accedés a un <strong class="text-emerald-700"
                >40% de descuento</strong
              >
            </li>
            <li>✔ Podés pagar online o presencialmente</li>
            <li>✔ El sistema emite comprobante oficial</li>
            <li>
              ✔ Luego del vencimiento se pierde el descuento y se actualiza el
              monto
            </li>
          </ul>
        </div>

        <!-- Plazos -->
        <div
          class="bg-slate-50 rounded-2xl p-7 shadow-sm border border-slate-200"
        >
          <div class="flex items-center gap-3 mb-4 text-indigo-700">
            <Clock size={22} />
            <h3 class="font-semibold text-slate-800">Descargos y recargos</h3>
          </div>
          <ul class="space-y-2 text-sm text-slate-700">
            <li>
              ✔ Si presentás descargo, <strong>perdés el descuento</strong>
            </li>
            <li>✔ Pasados los 30 días entra en <strong>rebeldía</strong></li>
            <li>✔ En rebeldía se quita el descuento y se suma recargo</li>
            <li>✔ Algunas faltas requieren resolución judicial previa</li>
          </ul>
        </div>
      </div>

      <div
        class="mt-10 bg-blue-50 border border-blue-100 rounded-2xl p-6 text-sm text-slate-700 max-w-6xl mx-auto"
      >
        💡 <strong>Recomendación:</strong> Consultá tu multa online antes de acercarte
        para confirmar estado, monto actualizado y documentación necesaria.
      </div>
    </div>
  </section>

  <!-- Accesos principales -->
  <section class="bg-slate-100 py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-bold text-slate-800 text-center mb-3">
        ¿Qué documentación y plazos debés tener en cuenta para resolver tu
        multa?
      </h2>
      <p class="text-center text-slate-500 mb-12">
        Accedé directamente a los trámites más usados
      </p>

      <div class="grid gap-7 md:grid-cols-3">
        <!-- Pagos -->
        <a
          href="https://pagosonlinejuzgado.netlify.app/"
          target="_blank"
          rel="noreferrer"
          class="group bg-slate-50 rounded-2xl p-7 shadow-sm hover:shadow-md transition hover:-translate-y-1 border border-slate-200"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="bg-indigo-100 text-indigo-700 p-3 rounded-xl">
              <CircleDollarSign size={22} />
            </div>
            <h3 class="font-semibold text-lg text-slate-800">
              Quiero pagar una multa
            </h3>
          </div>
          <p class="text-slate-600 text-sm mb-5">
            Pagá online de forma segura con los medios habilitados.
          </p>
          <span class="text-indigo-700 font-semibold group-hover:underline">
            Ir al pago →
          </span>
        </a>

        <!-- Libre deuda -->
        <a
          href="https://libredeuda.apps.cc.gob.ar/"
          target="_blank"
          rel="noreferrer"
          class="group bg-slate-50 rounded-2xl p-7 shadow-sm hover:shadow-md transition hover:-translate-y-1 border border-slate-200"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="bg-emerald-100 text-emerald-700 p-3 rounded-xl">
              <FileText size={22} />
            </div>
            <h3 class="font-semibold text-lg text-slate-800">
              Necesito libre deuda
            </h3>
          </div>
          <p class="text-slate-600 text-sm mb-5">
            Solicitá tu certificado en minutos desde el sistema oficial.
          </p>
          <span class="text-emerald-700 font-semibold group-hover:underline">
            Solicitar →
          </span>
        </a>

        <!-- Multas -->
        <a
          href="https://multasinfojuzgado.netlify.app/"
          target="_blank"
          rel="noreferrer"
          class="group bg-slate-50 rounded-2xl p-7 shadow-sm hover:shadow-md transition hover:-translate-y-1 border border-slate-200"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="bg-blue-100 text-blue-700 p-3 rounded-xl">
              <HelpCircle size={22} />
            </div>
            <h3 class="font-semibold text-lg text-slate-800">
              Tengo una multa
            </h3>
          </div>
          <p class="text-slate-600 text-sm mb-5">
            Consultá qué significa, si está vigente y qué opciones tenés para
            resolverla.
          </p>
          <span class="text-blue-700 font-semibold group-hover:underline">
            Ver información →
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Cómo funciona -->
  <!-- <section class="bg-slate-100 py-12 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-slate-800 mb-10">
        ¿Cómo podés consultar y resolver tu multa paso a paso?
      </h2>

      <div class="grid gap-7 md:grid-cols-3">
        <div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200">
